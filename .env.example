# =============================================================================
# Claude Automation Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# ----------------------------------------------------------------------------
# LLM Provider
# Default: ollama (free, local, runs on GTX 1060)
# Set to "anthropic" to use Claude API for complex reasoning
# ----------------------------------------------------------------------------
MODEL_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional: Anthropic API fallback (only needed if MODEL_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------------------------
# WhatsApp
# Phone number to send approval requests to (international format, e.g. +541112345678)
# ----------------------------------------------------------------------------
WHATSAPP_NOTIFY_NUMBER=+54

# Path to the whatsapp-mcp Go binary (default: ~/.local/bin/whatsapp-mcp)
# WHATSAPP_MCP_BIN=/home/youruser/.local/bin/whatsapp-mcp

# ----------------------------------------------------------------------------
# Agent Behavior
# ----------------------------------------------------------------------------
# Data directory for OAuth tokens, WhatsApp session, logs, pending actions
DATA_DIR=data

# How long pending actions wait for approval before expiring (hours)
APPROVAL_EXPIRY_HOURS=24

# Max emails to process per agent cycle
MAX_EMAILS_PER_CYCLE=5

# How far ahead to look for calendar events (hours)
CALENDAR_LOOKAHEAD_HOURS=24

# Polling interval for --loop mode (seconds, default 15 min)
POLL_INTERVAL_SECONDS=900

# Set to "true" to enable Playwright MCP for web tasks
ENABLE_PLAYWRIGHT=false
